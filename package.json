{
  "name": "factoring-hot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "fetch": "node --env-file-if-exists=.env.local ./node_modules/tsx/dist/cli.mjs src/scripts/fetch-sources.ts",
    "score": "node --env-file-if-exists=.env.local ./node_modules/tsx/dist/cli.mjs src/scripts/llm-score.ts",
    "cluster": "node --env-file-if-exists=.env.local ./node_modules/tsx/dist/cli.mjs src/scripts/cluster-events.ts",
    "report": "node --env-file-if-exists=.env.local ./node_modules/tsx/dist/cli.mjs src/scripts/generate-reports.ts daily",
    "init": "node --env-file-if-exists=.env.local ./node_modules/tsx/dist/cli.mjs src/scripts/init-sources.ts",
    "report:weekly": "node --env-file-if-exists=.env.local ./node_modules/tsx/dist/cli.mjs src/scripts/generate-reports.ts weekly",
    "report:monthly": "node --env-file-if-exists=.env.local ./node_modules/tsx/dist/cli.mjs src/scripts/generate-reports.ts monthly"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cheerio": "^1.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.469.0",
    "next": "^16.2.10",
    "openai": "^4.72.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rss-parser": "^3.13.0",
    "undici": "^6.0.0"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.0",
    "pg": "^8.22.0",
    "postcss": "8.5.16",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
